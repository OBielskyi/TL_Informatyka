'''
kalkulator w pythonie (nie uzywa "jednego try")
version 1.1
'''
def wczytaj_liczbe(tekst):
    try:
        return float(input(tekst))
    except ValueError:
        print("Błąd: wprowadzono niepoprawne dane (to nie liczba)")
        return None


def wykonaj_dzialanie(a, op, b):
    if op == "+":
        return a + b
    elif op == "-":
        return a - b
    elif op == "*":
        return a * b
    elif op == "/":
        if b == 0:
            print("Błąd: dzielenie przez 0")
            return None
        return a / b
    else:
        print("Błąd: nieznana operacja")
        return None


def kalkulator():
    a = wczytaj_liczbe("Podaj pierwszą liczbę: ")
    if a is None:
        return

    op = input("Podaj operację (+, -, *, /): ")

    b = wczytaj_liczbe("Podaj drugą liczbę: ")
    if b is None:
        return

    wynik = wykonaj_dzialanie(a, op, b)
    if wynik is not None:
        print("Wynik:", wynik)


kalkulator()
